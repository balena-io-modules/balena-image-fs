  "license": "Apache-2.0",
  "devDependencies": {
    "@balena/lint": "^9.1.6",
    "@types/mocha": "10.0.10",
    "@types/node": "20.19.43",
    "@types/tmp": "0.2.6",
    "jsdoc-to-markdown": "9.1.3",
    "mocha": "11.7.6",
    "tmp": "0.2.7",
    "ts-node": "10.9.2",
    "typescript": "5.9.3"
  },
  "dependencies": {
    "ext2fs": "^4.2.4",
    "fatfs": "^0.10.8",
    "file-disk": "^8.0.1",
