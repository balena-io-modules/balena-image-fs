{
  "name": "balena-image-fs",
  "version": "7.6.18",
  "description": "Image filesystem manipulation utilities",
  "main": "build/index.js",
  "homepage": "https://github.com/balena-io-modules/balena-image-fs",
  "repository": {
    "type": "git",
